```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
build/
dist/
*.out

# Dependencies
.venv/
venv/
node_modules/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage
.coverage
coverage/
htmlcov/

# MyPy
.mypy_cache/

# Pytest
.pytest_cache/
```